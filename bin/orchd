#!/usr/bin/env bash
set -euo pipefail

# --- Dependency checks ---
for dep in git tmux awk cmp diff; do
  command -v "$dep" >/dev/null 2>&1 || {
    printf 'orchd: required command not found: %s\n' "$dep" >&2
    exit 1
  }
done

resolve_path() {
  local target=$1
  if command -v realpath >/dev/null 2>&1; then
    realpath "$target"
  else
    local dir
    dir=$(dirname "$target")
    printf '%s/%s\n' "$(cd "$dir" && pwd -P)" "$(basename "$target")"
  fi
}

# --- Resolve paths ---
SELF="$(resolve_path "$0")"
export ORCHD_BIN="$SELF"
ORCHD_LIB_DIR="$(dirname "$SELF")/../lib"

# --- Source libraries ---
# shellcheck source=../lib/core.sh
source "$ORCHD_LIB_DIR/core.sh"
# shellcheck source=../lib/runner.sh
source "$ORCHD_LIB_DIR/runner.sh"
# shellcheck source=../lib/swarm.sh
source "$ORCHD_LIB_DIR/swarm.sh"
# shellcheck source=../lib/decision_trace.sh
source "$ORCHD_LIB_DIR/decision_trace.sh"
# shellcheck source=../lib/verify.sh
source "$ORCHD_LIB_DIR/verify.sh"
# shellcheck source=../lib/recovery.sh
source "$ORCHD_LIB_DIR/recovery.sh"
# shellcheck source=../lib/cmd/init.sh
source "$ORCHD_LIB_DIR/cmd/init.sh"
# shellcheck source=../lib/cmd/plan.sh
source "$ORCHD_LIB_DIR/cmd/plan.sh"
# shellcheck source=../lib/cmd/review.sh
source "$ORCHD_LIB_DIR/cmd/review.sh"
# shellcheck source=../lib/cmd/spawn.sh
source "$ORCHD_LIB_DIR/cmd/spawn.sh"
# shellcheck source=../lib/cmd/board.sh
source "$ORCHD_LIB_DIR/cmd/board.sh"
# shellcheck source=../lib/cmd/check.sh
source "$ORCHD_LIB_DIR/cmd/check.sh"
# shellcheck source=../lib/cmd/merge.sh
source "$ORCHD_LIB_DIR/cmd/merge.sh"
# shellcheck source=../lib/cmd/doctor.sh
source "$ORCHD_LIB_DIR/cmd/doctor.sh"
# shellcheck source=../lib/cmd/agent_prompt.sh
source "$ORCHD_LIB_DIR/cmd/agent_prompt.sh"
# shellcheck source=../lib/cmd/refresh_docs.sh
source "$ORCHD_LIB_DIR/cmd/refresh_docs.sh"
# shellcheck source=../lib/cmd/resume.sh
source "$ORCHD_LIB_DIR/cmd/resume.sh"
# shellcheck source=../lib/cmd/autopilot.sh
source "$ORCHD_LIB_DIR/cmd/autopilot.sh"
# shellcheck source=../lib/cmd/orchestrate.sh
source "$ORCHD_LIB_DIR/cmd/orchestrate.sh"
# shellcheck source=../lib/cmd/state.sh
source "$ORCHD_LIB_DIR/cmd/state.sh"
# shellcheck source=../lib/cmd/reconcile.sh
source "$ORCHD_LIB_DIR/cmd/reconcile.sh"
# shellcheck source=../lib/cmd/await.sh
source "$ORCHD_LIB_DIR/cmd/await.sh"
# shellcheck source=../lib/cmd/memory.sh
source "$ORCHD_LIB_DIR/cmd/memory.sh"
# shellcheck source=../lib/cmd/idea.sh
source "$ORCHD_LIB_DIR/cmd/idea.sh"
# shellcheck source=../lib/cmd/fleet.sh
source "$ORCHD_LIB_DIR/cmd/fleet.sh"
# shellcheck source=../lib/cmd/ideate.sh
source "$ORCHD_LIB_DIR/cmd/ideate.sh"

# --- Usage ---
usage() {
  cat <<'EOF'
orchd - autonomous AI agent orchestrator

Orchestration commands:
  orchd init   [dir] [description]     Initialize orchd in a project
  orchd plan   [--runner <runner>] "<description>"   Generate task DAG with AI
  orchd review [ref] | --task <id>     Run review-only agent on changes or a task diff
  orchd spawn  <task-id> | --all       Create worktrees & launch agents
  orchd board  [--watch]               Live agent status dashboard
  orchd tui    [--project <dir>]       Rich terminal UI dashboard (Go binary)
  orchd state  [--json]                Print task state snapshot
  orchd await  [--all|<task-id>]       Block until a task changes or agent exits
  orchd reconcile [--dry-run]          Reconcile orchd state with git reality
  orchd check  <task-id> | --all       Run quality gates on tasks
  orchd merge  <task-id> | --all       Merge completed tasks (DAG order)
  orchd resume <task-id> [reason...]    Resume/continue a task in its worktree
  orchd orchestrate [poll_seconds]      AI orchestrator loop with system reminders
  orchd orchestrate --once              Run a single orchestrator turn
  orchd orchestrate --daemon [poll]     Run orchestrator supervisor in background
  orchd orchestrate --status            Show orchestrator daemon status
  orchd orchestrate --stop              Stop orchestrator daemon
  orchd orchestrate --logs              Tail orchestrator daemon log
  orchd autopilot [poll_seconds]        Default AI orchestrator supervisor loop
  orchd autopilot --ai-orchestrated     Explicit AI orchestrator supervisor mode
  orchd autopilot --deterministic       Legacy deterministic spawn/check/merge loop
  orchd autopilot --continuous [poll]   Compatibility flag (implicit in AI mode)
  orchd autopilot --daemon [poll]       Run autopilot in background
  orchd autopilot --status              Show active autopilot daemon status
  orchd autopilot --stop                Stop active autopilot daemon
  orchd autopilot --logs                Tail active autopilot daemon log
  orchd finish [poll_seconds]           Throughput-first project finisher loop
  orchd finish --daemon [poll]          Run finisher loop in background
  orchd finish --status                 Show active finisher daemon status
  orchd finish --stop                   Stop active finisher daemon
  orchd finish --logs                   Tail active finisher daemon log
  orchd agent-prompt [role] [goal...]   Print a copy-paste prompt for an external agent
  orchd doctor [dir]                   Show effective config and auto-detect
  orchd refresh-docs [dir]             Refresh AGENTS/WORKER/ORCHESTRATOR/CLAUDE/OPENCODE/runbook docs

Memory bank:
  orchd memory                         Show memory bank status
  orchd memory init                    Initialize memory bank scaffold
  orchd memory show                    Print all memory bank contents
  orchd memory update                  Update progress/context from task state
  orchd memory reset --force           Remove all memory bank files

Idea queue:
  orchd idea "<idea>"                  Queue an idea for continuous autopilot
  orchd idea list                      List queued ideas
  orchd idea count                     Count pending ideas
  orchd idea clear --force             Remove all pending ideas

Fleet management:
  orchd fleet list                     List configured fleet projects
  orchd fleet autopilot [opts]         Start autopilot for all fleet projects (default AI mode)
  orchd fleet status                   Show fleet autopilot status
  orchd fleet stop                     Stop all fleet autopilot daemons
  orchd fleet brief [hours]            Summary of recent activity (default 24h)

Ideation:
  orchd ideate                         Generate next ideas from project goals
  orchd ideate --dry-run               Show suggestions without queueing

Runner notes:
  - Codex runs sandboxed by default. Configure `codex_flags` in .orchd.toml if needed.

Monitor commands:
  orchd start  [repo_dir] [interval]   Start background repo monitor
  orchd attach <session>               Attach to monitor session
  orchd stop   <session>               Stop monitor session
  orchd list                           List active sessions
  orchd status <session>               Show monitor snapshot

Environment:
  ORCHD_BRANCH_REGEX   Regex for refs to track (default: ^origin/(main|agent-|orchestrator/))
  ORCHD_STATE_DIR      Monitor state dir (default: $HOME/.orchd)

Workflow:
  orchd agent-prompt orchestrator "build a REST API with auth, tests, and CI"
  # paste that into your coding agent, or run manually:
  orchd init .
  orchd plan "build a REST API with auth, tests, and CI"
  orchd finish                           # recommended project-finisher path
  # or step-by-step:
  orchd spawn --all
  orchd board --watch
  orchd check --all
  orchd merge --all

Continuous mode:
  orchd autopilot --continuous            # runs until PROJECT_COMPLETE
EOF
}

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

# --- Command parsing ---
cmd=${1:-}
shift || true

# --- Monitor helpers (kept from original) ---

state_dir_default() {
  printf '%s\n' "${ORCHD_STATE_DIR:-$HOME/.orchd}"
}

session_default() {
  local repo_dir=$1
  local base
  base=$(basename "$repo_dir")
  # Sanitize: keep only alphanumeric, dot, hyphen, underscore
  base=${base//[^a-zA-Z0-9._-]/_}
  printf '%s\n' "orchd-${base}"
}

tick() {
  local repo_dir=$1
  local session=$2

  local state_dir
  state_dir=$(state_dir_default)
  mkdir -p "$state_dir/$session"

  local ts
  ts=$(now_iso)

  # Fetch can fail (offline); don't crash the daemon.
  git -C "$repo_dir" fetch --all --prune >/dev/null 2>&1 || true

  {
    printf '== %s ==\n' "$ts"
    git -C "$repo_dir" status -sb || true
    printf '\n'
  } >"$state_dir/$session/snapshot.txt"

  local branch_regex
  branch_regex=${ORCHD_BRANCH_REGEX:-'^origin/(main|agent-|orchestrator/)'}

  git -C "$repo_dir" for-each-ref refs/remotes/origin \
    --format='%(refname:short) %(objectname:short)' \
    | awk -v re="$branch_regex" '$1 ~ re { print $0 }' \
    | sort >"$state_dir/$session/refs.current"

  if [[ -f "$state_dir/$session/refs.last" ]]; then
    if ! cmp -s "$state_dir/$session/refs.last" "$state_dir/$session/refs.current"; then
      local log_file="$state_dir/$session/changes.log"
      # Rotate log if it exceeds ~10 MB
      if [[ -f "$log_file" ]]; then
        local log_size
        log_size=$(wc -c < "$log_file" 2>/dev/null || printf '0')
        if (( log_size > 10485760 )); then
          mv -f "$log_file" "${log_file}.1"
        fi
      fi
      {
        printf '== %s ==\n' "$ts"
        diff -u "$state_dir/$session/refs.last" "$state_dir/$session/refs.current" || true
        printf '\n'
      } >>"$log_file"
    fi
  fi

  mv -f "$state_dir/$session/refs.current" "$state_dir/$session/refs.last"
}

run_daemon() {
  local repo_dir=$1
  local interval=$2
  local session=$3

  while true; do
    tick "$repo_dir" "$session" || true
    sleep "$interval"
  done
}

# --- Dispatch ---
case "$cmd" in
  # === Orchestration commands ===
  init)
    cmd_init "$@"
    ;;
  plan)
    cmd_plan "$@"
    ;;
  review)
    cmd_review "$@"
    ;;
  spawn)
    cmd_spawn "$@"
    ;;
  board)
    cmd_board "$@"
    ;;
  tui)
    local_tui_bin="$(dirname "$SELF")/orchd-tui"
    repo_root="$(dirname "$SELF")/.."

    if [[ -d "$repo_root/cmd/orchd-tui" ]] && command -v go >/dev/null 2>&1; then
      need_build=0
      if [[ ! -x "$local_tui_bin" ]]; then
        need_build=1
      else
        for src_file in "$repo_root"/cmd/orchd-tui/*.go "$repo_root"/go.mod "$repo_root"/go.sum; do
          [[ -e "$src_file" ]] || continue
          if [[ "$src_file" -nt "$local_tui_bin" ]]; then
            need_build=1
            break
          fi
        done
      fi

      if [[ "$need_build" -eq 1 ]]; then
        if ! (cd "$repo_root" && go build -o "$local_tui_bin" ./cmd/orchd-tui >/dev/null 2>&1); then
          printf '%s\n' "orchd: failed to build local orchd-tui binary" >&2
        fi
      fi
    fi

    if [[ -x "$local_tui_bin" ]]; then
      "$local_tui_bin" "$@"
    elif command -v orchd-tui >/dev/null 2>&1; then
      orchd-tui "$@"
    else
      printf '%s\n' "orchd: orchd-tui binary not found"
      printf '%s\n' "build it with: go build -o bin/orchd-tui ./cmd/orchd-tui"
      printf '%s\n' "falling back to: orchd board"
      cmd_board
    fi
    ;;
  state)
    cmd_state "$@"
    ;;
  await)
    cmd_await "$@"
    ;;
  reconcile|reconcile-state|repair)
    cmd_reconcile "$@"
    ;;
  check)
    cmd_check "$@"
    ;;
  merge)
    cmd_merge "$@"
    ;;
  resume)
    cmd_resume "$@"
    ;;
  orchestrate)
    cmd_orchestrate "$@"
    ;;
  doctor)
    cmd_doctor "$@"
    ;;
  agent-prompt|agent_prompt|prompt)
    cmd_agent_prompt "$@"
    ;;
  refresh-docs|refresh_docs)
    cmd_refresh_docs "$@"
    ;;
  autopilot)
    cmd_autopilot "$@"
    ;;
  finish)
    cmd_finish "$@"
    ;;
  memory)
    cmd_memory "$@"
    ;;
  idea)
    cmd_idea "$@"
    ;;
  fleet)
    cmd_fleet "$@"
    ;;
  ideate)
    cmd_ideate "$@"
    ;;

  # === Monitor commands (original) ===
  start)
    repo_dir=${1:-$PWD}
    interval=${2:-30}
    [[ -d "$repo_dir" ]] || die "repo_dir not found: $repo_dir"
    [[ "$interval" =~ ^[0-9]+$ ]] || die "interval must be integer seconds"
    session=${ORCHD_SESSION:-$(session_default "$repo_dir")}

    tmux has-session -t "$session" 2>/dev/null && die "already running: $session"
    tmux new -d -s "$session" "$SELF __run '${repo_dir}' '${interval}' '${session}'"
    printf '%s\n' "started: $session (repo=$repo_dir interval=${interval}s)"
    ;;
  __run)
    repo_dir=${1:?}
    interval=${2:?}
    session=${3:?}
    run_daemon "$repo_dir" "$interval" "$session"
    ;;
  attach)
    session=${1:-}
    [[ -n "$session" ]] || die "session required"
    tmux attach -t "$session"
    ;;
  stop)
    session=${1:-}
    [[ -n "$session" ]] || die "session required"
    tmux kill-session -t "$session"
    printf '%s\n' "stopped: $session"
    ;;
  list)
    sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | awk '/^orchd-/' || true)
    if [[ -n "$sessions" ]]; then
      printf '%s\n' "$sessions"
    else
      printf '%s\n' "no active orchd sessions"
    fi
    ;;
  status)
    session=${1:-}
    [[ -n "$session" ]] || die "session required"
    if tmux has-session -t "$session" 2>/dev/null; then
      printf '%s\n' "running: $session"
      state_dir=$(state_dir_default)
      if [[ -f "$state_dir/$session/snapshot.txt" ]]; then
        printf '\n'
        sed -n '1,12p' "$state_dir/$session/snapshot.txt" || true
      else
        printf '%s\n' "(no snapshot yet — waiting for first tick)"
      fi
    else
      die "not running: $session"
    fi
    ;;

  # === Help / fallback ===
  -h|--help|help|'')
    usage
    ;;
  *)
    die "unknown command: $cmd (try --help)"
    ;;
esac
